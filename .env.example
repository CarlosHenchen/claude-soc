# ----------------------------------------------------------------------------
# Viaconnect SOC Maturity — environment variables
# Copy to `.env` and adjust. The .env file is read by docker-compose.
# ----------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=soc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=soc_maturity
# Host:port are internal to the compose network; not published to the host.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- API ---
# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-generate-a-long-random-secret
# Token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Uvicorn workers (suba para 2-4 em produção; PDF/Playwright bloqueia 1 worker).
UVICORN_WORKERS=1

# Seed admin user (created on first boot if it does not exist).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_FULL_NAME=Administrador

# Directory (inside the api container) where framework spreadsheets are mounted.
FRAMEWORKS_DIR=/frameworks
# Source workbook filename used by the seeder / re-seed endpoint.
SEED_WORKBOOK=Viaconnect_HealthCheck_Dominios_SOC_COMPLETOv2.xlsx

# Run DB seed automatically on container start (1 = yes, 0 = no).
AUTO_SEED=1

# --- Web (build-time, optional) ---
# The web container proxies /api to the api service, so this is usually empty.
VITE_API_BASE=/api

# --- Host port published by the web container ---
WEB_PORT=8080
